{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "references": [
    { "path": "../kernel" },
    { "path": "../player" }
  ],
  "include": [
    "domain/**/*",
    "application/**/*",
    "infrastructure/**/*",
    "presentation/**/*",
    "index.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.property.test.ts",
    "**/*test-utils.ts"
  ]
}
