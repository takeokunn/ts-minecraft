{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable", "WebWorker"],
    "allowJs": false,
    "checkJs": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "removeComments": false,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "useUnknownInCatchVariables": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/test/*": ["test/*"],
      "@ts-minecraft/kernel": ["packages/kernel/index.ts"],
      "@ts-minecraft/domain": ["packages/domain/index.ts"],
      "@ts-minecraft/noise-generator": ["packages/noise-generator/index.ts"],
      "@ts-minecraft/block-storage": ["packages/block-storage/index.ts"],
      "@ts-minecraft/physics-engine": ["packages/physics-engine/index.ts"],
      "@ts-minecraft/terrain-generator": ["packages/terrain-generator/index.ts"],
      "@ts-minecraft/biome-classifier": ["packages/biome-classifier/index.ts"],
      "@ts-minecraft/chunk-manager": ["packages/chunk-manager/index.ts"],
      "@ts-minecraft/world-renderer": ["packages/world-renderer/index.ts"],
      "@ts-minecraft/world-renderer/*": ["packages/world-renderer/*"],
      "@ts-minecraft/block-service": ["packages/block-service/index.ts"],
      "@ts-minecraft/fluid-simulation": ["packages/fluid-simulation/index.ts"],
      "@ts-minecraft/light-engine": ["packages/light-engine/index.ts"],
      "@ts-minecraft/redstone-circuit": ["packages/redstone-circuit/index.ts"],
      "@ts-minecraft/player-controller": ["packages/player-controller/index.ts"],
      "@ts-minecraft/camera-controller": ["packages/camera-controller/index.ts"],
      "@ts-minecraft/input-handler": ["packages/input-handler/index.ts"],
      "@ts-minecraft/inventory-system": ["packages/inventory-system/index.ts"],
      "@ts-minecraft/hotbar-system": ["packages/hotbar-system/index.ts"],
      "@ts-minecraft/crafting-system": ["packages/crafting-system/index.ts"],
      "@ts-minecraft/furnace-system": ["packages/furnace-system/index.ts"],
      "@ts-minecraft/game-mode": ["packages/game-mode/index.ts"],
      "@ts-minecraft/settings-manager": ["packages/settings-manager/index.ts"],
      "@ts-minecraft/day-night-cycle": ["packages/day-night-cycle/index.ts"],
      "@ts-minecraft/audio-engine": ["packages/audio-engine/index.ts"],
      "@ts-minecraft/entity-manager": ["packages/entity-manager/index.ts"],
      "@ts-minecraft/village-system": ["packages/village-system/index.ts"],
      "@ts-minecraft/trading-system": ["packages/trading-system/index.ts"],
      "@ts-minecraft/game-session": ["packages/game-session/index.ts"],
      "@ts-minecraft/game-loop": ["packages/game-loop/index.ts"],
      "@ts-minecraft/app": ["packages/app/index.ts"],
      "@ts-minecraft/app/*": ["packages/app/*"],
      "@ts-minecraft/terrain-worker-pool": ["packages/terrain-worker-pool/index.ts"],
      "@ts-minecraft/environment": ["packages/environment/index.ts"],
      "@ts-minecraft/perf-hud": ["packages/perf-hud/index.ts"]
    },
    "types": [],
    "typeRoots": ["node_modules/@types", "src/types", "types"],
    "sourceRoot": "./src",
    "mapRoot": "./dist",
    "inlineSources": false,
    "newLine": "lf",
    "stripInternal": true,
    "preserveSymlinks": true,
    "moduleDetection": "force",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolvePackageJsonExports": true,
    "resolvePackageJsonImports": true,
    "allowArbitraryExtensions": false,
    "importsNotUsedAsValues": "remove"
  },
  "include": ["src/main.ts", "test/**/*", "types/**/*"],
  "exclude": ["node_modules", "dist", "coverage", "docs"],
  "watchOptions": {
    "excludeDirectories": ["**/node_modules", "**/.git", "**/dist"],
    "excludeFiles": ["**/*.js.map", "**/*.d.ts.map"]
  }
}
