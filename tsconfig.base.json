{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2024",
      "DOM",
      "DOM.Iterable",
      "WebWorker"
    ],
    "allowJs": false,
    "checkJs": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "useUnknownInCatchVariables": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "newLine": "lf",
    "stripInternal": true,
    "preserveSymlinks": true,
    "moduleDetection": "force",
    "resolvePackageJsonExports": true,
    "resolvePackageJsonImports": true,
    "paths": {
      "@test/*": [
        "test/*"
      ],
      "@ts-minecraft/core": [
        "packages/core/index.ts"
      ],
      "@ts-minecraft/block": [
        "packages/block/index.ts"
      ],
      "@ts-minecraft/entity": [
        "packages/entity/index.ts"
      ],
      "@ts-minecraft/inventory": [
        "packages/inventory/index.ts"
      ],
      "@ts-minecraft/network": [
        "packages/network/index.ts"
      ],
      "@ts-minecraft/network/*": [
        "packages/network/*"
      ],
      "@ts-minecraft/world": [
        "packages/world/index.ts"
      ],
      "@ts-minecraft/game": [
        "packages/game/index.ts"
      ],
      "@ts-minecraft/rendering/particles/particle-system": [
        "packages/rendering/infrastructure/particles/particle-system"
      ],
      "@ts-minecraft/rendering/*": [
        "packages/rendering/*"
      ],
      "@ts-minecraft/rendering": [
        "packages/rendering/index.ts"
      ],
      "@ts-minecraft/worker/*": [
        "packages/worker/*"
      ],
      "@ts-minecraft/worker": [
        "packages/worker/index.ts"
      ],
      "@ts-minecraft/presentation/*": [
        "packages/presentation/*"
      ],
      "@ts-minecraft/presentation": [
        "packages/presentation/index.ts"
      ],
      "@ts-minecraft/app/frame-handler.config": [
        "packages/app/application/frame-handler.config"
      ],
      "@ts-minecraft/app/frame-handler": [
        "packages/app/application/frame-handler"
      ],
      "@ts-minecraft/app/frame/*": [
        "packages/app/application/frame/*"
      ],
      "@ts-minecraft/app/main.config": [
        "packages/app/application/main.config"
      ],
      "@ts-minecraft/app/main/*": [
        "packages/app/application/main/*"
      ],
      "@ts-minecraft/app/*": [
        "packages/app/*"
      ],
      "@ts-minecraft/app": [
        "packages/app/index.ts"
      ],
      "@ts-minecraft/core/*": [
        "packages/core/*"
      ],
      "@ts-minecraft/block/*": [
        "packages/block/*"
      ],
      "@ts-minecraft/entity/*": [
        "packages/entity/*"
      ],
      "@ts-minecraft/inventory/*": [
        "packages/inventory/*"
      ],
      "@ts-minecraft/world/*": [
        "packages/world/*"
      ],
      "@ts-minecraft/game/*": [
        "packages/game/*"
      ]
    },
    "baseUrl": "."
  }
}
