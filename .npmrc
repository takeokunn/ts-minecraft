# Hoist fast-check for TypeScript type resolution
# fast-check is a transitive dependency of effect (via effect/FastCheck re-export)
# but pnpm does not hoist it by default; this makes its types available to tsc
public-hoist-pattern[]=fast-check
# pure-rand is a runtime dependency of fast-check; must be hoisted alongside it
# so Vite can resolve it from the flat node_modules/fast-check location
public-hoist-pattern[]=pure-rand
